class Hmm:
    def __init__(self, num_states: int) -> None: ...
    @property
    def num_states(self) -> int: ...
    def validate(self) -> None: ...
    def set_pi(self, pi: NDArray[np.float64]) -> None: ...
    def get_pi(self) -> NDArray[np.float64]: ...
    def set_trans(self, trans: NDArray[np.float64]) -> None: ...
    def get_trans(self) -> NDArray[np.float64]: ...
    def set_distribution(self, state: int, distribution: EmissionDistribution) -> None: ...
    def get_distribution(self, state: int) -> EmissionDistribution: ...
    def get_distribution_name(self, state: int) -> str: ...

class ForwardBackwardCalculator:
    def __init__(self, hmm: Hmm, observations: NDArray[np.float64]) -> None: ...
    def compute(self, observations: NDArray[np.float64] | None = None) -> None: ...
    @property
    def log_probability(self) -> float: ...
    @property
    def probability(self) -> float: ...
    def get_log_forward_variables(self) -> NDArray[np.float64]: ...
    def get_log_backward_variables(self) -> NDArray[np.float64]: ...
    @property
    def num_states(self) -> int: ...

class ViterbiCalculator:
    def __init__(self, hmm: Hmm, observations: NDArray[np.float64]) -> None: ...
    def decode(self) -> NDArray[np.int64]: ...
    @property
    def log_probability(self) -> float: ...
    def get_state_sequence(self) -> NDArray[np.int64]: ...
    @property
    def num_states(self) -> int: ...

class TrainingConfig:
    convergence_tolerance: float
    max_iterations: int
    convergence_window: int
    enable_progress_reporting: bool

class BaumWelchTrainer:
    def __init__(self, hmm: Hmm, sequences: list[NDArray[np.float64]]) -> None: ...
    def train(self) -> None: ...

class ViterbiTrainer:
    def __init__(self, hmm: Hmm, sequences: list[NDArray[np.float64]], config: TrainingConfig = ...) -> None: ...
    def train(self) -> None: ...
    @property
    def has_converged(self) -> bool: ...
    @property
    def reached_max_iterations(self) -> bool: ...
    @property
    def last_log_probability(self) -> float: ...
    @property
    def config(self) -> TrainingConfig: ...
    @config.setter
    def config(self, value: TrainingConfig) -> None: ...

class SegmentalKMeansTrainer:
    def __init__(self, hmm: Hmm, sequences: list[NDArray[np.float64]]) -> None: ...
    def train(self) -> None: ...
    @property
    def is_terminated(self) -> bool: ...

def training_preset_fast() -> TrainingConfig: ...
def training_preset_balanced() -> TrainingConfig: ...
def training_preset_precise() -> TrainingConfig: ...
def load_hmm(filepath: str) -> Hmm: ...
def save_hmm(hmm: Hmm, filepath: str) -> None: ...
