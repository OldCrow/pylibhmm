import numpy as np
from numpy.typing import NDArray

class EmissionDistribution:
    def pdf(self, x: float) -> float: ...
    def log_pdf(self, x: float | NDArray[np.float64]) -> float | NDArray[np.float64]: ...
    def fit(self, data: NDArray[np.float64]) -> None: ...
    def fit_weighted(self, data: NDArray[np.float64], weights: NDArray[np.float64]) -> None: ...
    def reset(self) -> None: ...
    @property
    def is_discrete(self) -> bool: ...

class Discrete(EmissionDistribution):
    def __init__(self, num_symbols: int = 10) -> None: ...
    def set_probability(self, index: int, value: float) -> None: ...
    def get_symbol_probability(self, index: int) -> float: ...
    @property
    def num_symbols(self) -> int: ...
    @property
    def mode(self) -> int: ...

class Binomial(EmissionDistribution):
    def __init__(self, n: int = 10, p: float = 0.5) -> None: ...
    @property
    def n(self) -> int: ...
    @n.setter
    def n(self, value: int) -> None: ...
    @property
    def p(self) -> float: ...
    @p.setter
    def p(self, value: float) -> None: ...

class NegativeBinomial(EmissionDistribution):
    def __init__(self, r: float = 5.0, p: float = 0.5) -> None: ...
    @property
    def r(self) -> float: ...
    @r.setter
    def r(self, value: float) -> None: ...
    @property
    def p(self) -> float: ...
    @p.setter
    def p(self, value: float) -> None: ...

class Poisson(EmissionDistribution):
    def __init__(self, lam: float = 1.0) -> None: ...
    @property
    def lam(self) -> float: ...
    @lam.setter
    def lam(self, value: float) -> None: ...
    @property
    def mean(self) -> float: ...
    @property
    def variance(self) -> float: ...

class Gaussian(EmissionDistribution):
    def __init__(self, mu: float = 0.0, sigma: float = 1.0) -> None: ...
    @property
    def mu(self) -> float: ...
    @mu.setter
    def mu(self, value: float) -> None: ...
    @property
    def sigma(self) -> float: ...
    @sigma.setter
    def sigma(self, value: float) -> None: ...
    @property
    def mean(self) -> float: ...
    @property
    def variance(self) -> float: ...
    @property
    def std(self) -> float: ...
    def cdf(self, x: float) -> float: ...

