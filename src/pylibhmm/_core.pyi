    def cdf(self, x: float) -> float: ...

class LogNormal(EmissionDistribution):
    """Log-normal distribution.

    ``mu`` and ``sigma`` are the log-space parameters (not the distribution mean/std).
    Use ``distribution_mean`` for E[X] = exp(mu + sigma^2/2).
    """
    def __init__(self, mu: float = 0.0, sigma: float = 1.0) -> None: ...
    @property
    def mu(self) -> float: ...
    @mu.setter
    def mu(self, value: float) -> None: ...
    @property
    def sigma(self) -> float: ...
    @sigma.setter
    def sigma(self, value: float) -> None: ...
    @property
    def distribution_mean(self) -> float: ...
    @property
    def mean(self) -> float: ...
    @property
    def variance(self) -> float: ...
    @property
    def std(self) -> float: ...

